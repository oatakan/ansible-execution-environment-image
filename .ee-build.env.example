# Copy this file to .ee-build.env for local authenticated builds.

# Path to a separate file that exports RHN_CS_API_OFFLINE_TOKEN.
# Relative paths are resolved from the repository root.
EE_BUILD_SECRETS_FILE=.ee-build.secrets.env

# Optional overrides for Automation Hub configuration.
# ANSIBLE_GALAXY_SERVER_AUTOMATION_HUB_URL=https://console.redhat.com/api/automation-hub/content/published/
# ANSIBLE_GALAXY_SERVER_AUTOMATION_HUB_AUTH_URL=https://sso.redhat.com/auth/realms/redhat-external/protocol/openid-connect/token
# ANSIBLE_GALAXY_SERVER_AUTOMATION_HUB_CLIENT_ID=cloud-services